# After linking Neon on Vercel, pull vars locally:
#   vercel env pull .env.development.local
#
# `next dev` loads .env.development.local; `next start` does not. This repo merges
# `.env.development.local` from next.config.mjs so AUTH_SECRET and other pulled vars
# apply to local `npm start`. On Vercel that file is absent, so only real env vars apply.
#
# Drizzle Kit (`npm run db:push`) loads .env, .env.local, and .env.*.local — not only `.env`.
#
# Vercel Blob (Storage → Blob); required for admin polaroid uploads
# BLOB_READ_WRITE_TOKEN=

# Neon (Vercel Storage): pooled connection for the app runtime
DATABASE_URL=
# Aliases set by some Vercel Postgres templates (optional fallback)
# POSTGRES_URL=

# Non-pooling URL for Drizzle Kit / migrations (recommended when available)
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL_NON_POOLING=

# Generate with: npx auth secret
AUTH_SECRET=

# Canonical site URL (include port for local). Required for correct OAuth redirects.
AUTH_URL=http://localhost:3000

# Trust the incoming Host header for Auth.js (required for /admin on http://localhost
# when AUTH_URL is your deploy URL). Default in code is trusted unless you set:
#   AUTH_TRUST_HOST=false
# on a locked-down self-hosted server behind a reverse proxy that validates Host.
AUTH_TRUST_HOST=true

# GitHub OAuth App (Settings → Developer settings)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth Client (Google Cloud Console → OAuth 2.0 Client IDs)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated emails allowed to sign in (admins). Others are denied at sign-in.
ADMIN_ALLOWED_EMAILS=you@example.com

# Resend (https://resend.com) — contact form at /about/contact (Vercel serverless)
# RESEND_API_KEY=
# Inbox for contact submissions (optional if ADMIN_ALLOWED_EMAILS has at least one address)
# CONTACT_TO_EMAIL=you@example.com
# "From" header — must be an address on a domain you verified in Resend (or onboarding@… for tests).
# After adding your domain in Resend and creating a sender address, pick one:
#   CONTACT_FROM_EMAIL=hello@yourdomain.com
#   CONTACT_FROM_NAME=Elissa Mentesana
# (bare email + name becomes "Elissa Mentesana <hello@yourdomain.com>" for Resend.)
# Or set the full header in one variable:
#   CONTACT_FROM_EMAIL=Elissa Mentesana <hello@yourdomain.com>
# Test mode (no domain): omit CONTACT_FROM_EMAIL; optional CONTACT_FROM_NAME uses onboarding@resend.dev
# CONTACT_FROM_EMAIL=
# CONTACT_FROM_NAME=

# If you use dotenvx encrypted files, Next and plain dotenv do not decrypt them unless
# you wrap commands, e.g. `dotenvx run -- npm run dev`. For local auth, plain KEY=value
# in .env.local is simplest. Run `npm run debug:connections` to verify wiring.
